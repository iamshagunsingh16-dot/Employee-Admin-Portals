<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Employee Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; padding: 0; }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
        }

        /* Left branding panel */
        .auth-brand {
            width: 45%;
            background: linear-gradient(145deg, #1a56db 0%, #0d47a1 60%, #083f9e 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2.5rem;
            color: white;
        }
        .auth-brand .brand-icon {
            width: 80px; height: 80px;
            background: rgba(255,255,255,0.15);
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.4rem;
            margin-bottom: 1.5rem;
            backdrop-filter: blur(8px);
        }
        .auth-brand h1 { font-size: 1.9rem; font-weight: 700; margin-bottom: .5rem; }
        .auth-brand p { opacity: .75; font-size: .97rem; text-align: center; max-width: 280px; line-height: 1.6; }

        .auth-brand .feature-list {
            list-style: none; padding: 0; margin: 2rem 0 0;
        }
        .auth-brand .feature-list li {
            display: flex; align-items: center; gap: .75rem;
            margin-bottom: .85rem; font-size: .88rem; opacity: .85;
        }
        .auth-brand .feature-list li i {
            width: 30px; height: 30px;
            background: rgba(255,255,255,.18);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 1rem;
        }

        /* Right form panel */
        .auth-form-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            background: #f8f9fb;
            overflow-y: auto;
        }
        .auth-form-box {
            width: 100%;
            max-width: 400px;
        }
        .auth-form-box .form-control {
            padding: .65rem 1rem;
            border-radius: 8px;
            border: 1.5px solid #dee2e6;
            transition: border-color .2s, box-shadow .2s;
        }
        .auth-form-box .form-control:focus {
            border-color: #1a56db;
            box-shadow: 0 0 0 3px rgba(26,86,219,.12);
        }
        .auth-form-box .input-group-text {
            border-radius: 8px 0 0 8px;
            border: 1.5px solid #dee2e6;
            border-right: none;
            background: white;
            color: #9ca3af;
        }
        .auth-form-box .input-group .form-control {
            border-radius: 0 8px 8px 0;
            border-left: none;
        }
        .auth-form-box .input-group:focus-within .input-group-text {
            border-color: #1a56db;
        }
        .btn-auth {
            width: 100%;
            padding: .7rem;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 8px;
        }
        .divider { display: flex; align-items: center; gap: 1rem; margin: 1.2rem 0; color: #9ca3af; font-size: .82rem; }
        .divider::before, .divider::after { content: ''; flex: 1; border-top: 1px solid #e5e7eb; }

        @@media (max-width: 768px) {
            .auth-brand { display: none; }
            .auth-form-panel { padding: 2rem 1.25rem; background: white; }
        }
    </style>
</head>
<body>
<div class="auth-wrapper">

    <!-- Left Panel -->
    <div class="auth-brand">
        <div class="brand-icon"><i class="bi bi-people-fill"></i></div>
        <h1>Employee Admin</h1>
        <p>A powerful portal to manage your entire workforce in one place.</p>

        <ul class="feature-list">
            <li><i class="bi bi-speedometer2"></i>Live dashboard &amp; statistics</li>
            <li><i class="bi bi-people"></i>Full employee directory</li>
            <li><i class="bi bi-shield-check"></i>Role-based access control</li>
            <li><i class="bi bi-pencil-square"></i>Add, edit &amp; remove employees</li>
        </ul>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-form-panel">
        <div class="auth-form-box">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
