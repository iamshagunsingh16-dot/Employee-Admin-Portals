@{
    ViewData["Title"] = "Access Denied";
    Layout = "_AuthLayout";
}

<div class="text-center py-3">
    <div class="mb-4" style="font-size:3.5rem; color:#ef4444;">
        <i class="bi bi-shield-x-fill"></i>
    </div>
    <h2 class="fw-bold mb-2" style="color:#111827;">Access Denied</h2>
    <p class="text-muted mb-4" style="font-size:.95rem;">
        You don't have permission to view this page.<br />
        This area requires the <strong>Admin</strong> role.
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-auth" style="max-width:220px;margin:0 auto;">
        <i class="bi bi-house me-2"></i>Back to Dashboard
    </a>
</div>
